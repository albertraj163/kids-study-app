# =============================================================================
# Kids Study App - Environment Variables
# Copy this file to .env and adjust values for your machine:
#   cp .env.example .env
# =============================================================================

# PostgreSQL connection (used by backend)
POSTGRES_USER=kidsapp
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=kids_study
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Backend API (use 3002 if port 3000 is taken, e.g. by Dokploy)
BACKEND_PORT=3002
NODE_ENV=production

# Frontend (nginx serves static files; API URL for browser)
API_URL=http://localhost:3002

# Docker image names (CI/CD builds and tags these)
BACKEND_IMAGE=kids-study-backend:latest
FRONTEND_IMAGE=kids-study-frontend:latest

# Local Docker registry (CI pushes images here on Ubuntu runners)
LOCAL_REGISTRY=localhost:5000

# Grafana UI port (use 3030 if 3001 is taken)
GRAFANA_PORT=3030

# Grafana admin login (change in production!)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
